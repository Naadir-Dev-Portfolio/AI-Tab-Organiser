{
  "manifest_version": 3,
  "name": "AI Tab Organiser",
  "version": "1.0",
  "description": "Instantly organise your open tabs into groups using AI",
  "icons": {
    "16":  "icon/ai_tab_organizer_logo.png",
    "32":  "icon/ai_tab_organizer_logo.png",
    "48":  "icon/ai_tab_organizer_logo.png",
    "128": "icon/ai_tab_organizer_logo.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "tabGroups",
    "scripting",
    "sidePanel",
    "windows"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://gemini.google.com/*"
  ],
  "action": {
    "default_title": "AI Tab Organiser",
    "default_icon": {
      "16": "icon/ai_tab_organizer_logo.png",
      "32": "icon/ai_tab_organizer_logo.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
